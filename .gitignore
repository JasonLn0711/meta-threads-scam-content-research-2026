.DS_Store
Thumbs.db

# Python and local tooling
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.codex

# Secrets and local configuration
.env
.env.*
*.pem
*.key
*.token

# Sensitive or raw research material
data/raw/*
data/interim/*
data/processed/*
data/private/
data/sensitive/
data/screenshots/
data/browser-exports/
data/browser-profiles/
data/evidence_store/*
data/audit_logs/*
data/learning_state/*
data/candidate_intake/candidate_stub_*.json
data/candidate_intake/closed_loop_round_*.jsonl
evidence/raw/
evidence/private/

# Keep data folder guidance trackable.
!data/raw/README.md
!data/interim/README.md
!data/processed/README.md
!data/evidence_store/README.md
!data/audit_logs/README.md
!data/learning_state/README.md
!data/samples/
!data/samples/README.md

# Generated outputs
outputs/
reports/generated/
*.log

# v2 Research Operating System metadata outputs.
# Keep raw/generated evidence blocked, but allow the current structured
# aggregate metadata reports requested by the v2 pipeline.
!outputs/
outputs/*
!outputs/sparse_clusters/
!outputs/sparse_clusters/latest.yaml
!outputs/embedding_clusters/
!outputs/embedding_clusters/latest.yaml
!outputs/discrepancy_reports/
!outputs/discrepancy_reports/latest.yaml
!outputs/research_candidates/
!outputs/research_candidates/*.md

# Keep the baseline-output guard file trackable while generated runs stay ignored.
!experiments/baselines/outputs/
!experiments/baselines/outputs/.gitignore
!experiments/evaluation-notes/outputs/
!experiments/evaluation-notes/outputs/.gitignore
